{
  "name": "devtoolbox",
  "private": true,
  "version": "1.0.0",
  "description": "套陆工具箱 - 免费在线开发工具桌面版",
  "author": "套陆聚合站",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "vite & electron .",
    "electron:build": "tsc -b && vite build && electron-builder",
    "electron:build:win": "tsc -b && vite build && electron-builder --win",
    "electron:build:mac": "tsc -b && vite build && electron-builder --mac"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@wasm-fmt/clang-format": "^22.1.5",
    "@wasm-fmt/gofmt": "^0.7.3",
    "@wasm-fmt/lua_fmt": "^0.3.3",
    "@wasm-fmt/ruff_fmt": "^0.15.12",
    "crypto-js": "^4.2.0",
    "heic2any": "^0.0.4",
    "js-yaml": "^4.1.1",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.16.0",
    "mqtt": "^5.15.1",
    "node-forge": "^1.4.0",
    "pdf-lib": "^1.17.1",
    "prettier": "^3.8.3",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "sql-formatter": "^15.8.0",
    "tailwindcss": "^4.3.0",
    "vite-plugin-wasm": "^3.6.0"
  },
  "build": {
    "appId": "cn.tlhub.devtoolbox",
    "productName": "套陆工具箱",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!dist/**/*.map",
      "!**/*.md",
      "!**/LICENSE*",
      "!**/CHANGELOG*",
      "!**/docs",
      "!**/test",
      "!**/tests",
      "!**/.github",
      "!**/node_modules/.cache",
      "!**/node_modules/@wasm-fmt/*/src",
      "!**/node_modules/@wasm-fmt/*/target",
      "!**/node_modules/@wasm-fmt/*/Cargo.toml",
      "!**/node_modules/@wasm-fmt/*/package.json",
      "!**/node_modules/prettier/plugins",
      "!**/node_modules/typescript/lib/typescript.js",
      "!**/node_modules/typescript/lib/tsserver.js"
    ],
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/crypto-js": "^4.2.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.3",
    "@types/node-forge": "^1.3.14",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "electron": "^41.7.1",
    "electron-builder": "^26.8.1"
  }
}
